# Election Education Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# ⚠️ NEVER commit real API keys to version control!

# ── Google Gemini API key (required for AI chat) ──
GOOGLE_API_KEY=

# ── Google Cloud project ID (required for Vertex AI moderation) ──
GOOGLE_CLOUD_PROJECT=
VERTEX_LOCATION=us-central1

# ── Google Translate API ──
GOOGLE_TRANSLATE_API_KEY=

# ── Google Text-to-Speech API ──
GOOGLE_TTS_API_KEY=

# ── Google Custom Search API ──
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# ── Google Analytics 4 ──
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google Maps Embed API ──
GOOGLE_MAPS_API_KEY=

# ── Firebase (optional persistence) ──
FIREBASE_CREDENTIALS_PATH=

# ── Flask ──
FLASK_SECRET_KEY=change-me-to-a-random-string

# ── CORS — comma-separated allowed origins (default: * for development) ──
ALLOWED_ORIGINS=*

# ── Port — Cloud Run injects this automatically ──
PORT=8080

# ── Timeouts ──
SEARCH_TIMEOUT_SECONDS=10
